{
    "name": "codenzia/browser-console",
    "description": "A web-based Artisan console, shell terminal, log viewer, and debug tool for Laravel — accessible from your browser, no database required.",
    "keywords": [
        "codenzia",
        "laravel",
        "artisan",
        "console",
        "terminal",
        "shell",
        "debug",
        "logs",
        "browser-console"
    ],
    "homepage": "https://github.com/codenzia/browser-console",
    "support": {
        "issues": "https://github.com/codenzia/browser-console/issues",
        "source": "https://github.com/codenzia/browser-console"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Codenzia",
            "email": "support@codenzia.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "livewire/livewire": "^3.0",
        "spatie/laravel-package-tools": "^1.17.0"
    },
    "require-dev": {
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-arch": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Codenzia\\BrowserConsole\\": "src/"
        },
        "files": [
            "src/Helpers/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Codenzia\\BrowserConsole\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Codenzia\\BrowserConsole\\BrowserConsoleServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
